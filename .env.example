# Canvas LMS connection (set these on your host, e.g. Render env vars)
#
# Your institution's Canvas base URL — the address you log in at.
# Examples: https://canvas.instructure.com  |  https://canvas.university.edu
CANVAS_BASE_URL=https://canvas.instructure.com

# Your Canvas personal access token.
# Get it in Canvas: Account -> Settings -> "+ New Access Token".
# https://community.canvaslms.com/t5/Student-Guide/How-do-I-manage-API-access-tokens-as-a-student/ta-p/273
CANVAS_API_TOKEN=your_canvas_access_token_here

# Optional: server port (Render/Heroku set PORT automatically)
# PORT=8000
